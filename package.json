{
  "name": "secure-publishing-platform-api",
  "version": "1.0.0",
  "description": "Secure Publishing Platform API is a production-style backend learning project for building a secure publishing and content-management API with authentication, authorization, database design, testing, documentation, and deployment practices.",
  "main": "src/server.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmarAbdelazeem/Secure-Publishing-Platform-API.git"
  },
  "keywords": [],
